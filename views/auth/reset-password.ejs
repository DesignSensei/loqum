<!-- views/auth/reset-password.ejs -->

<div class="d-flex flex-center flex-column flex-lg-row-fluid">
  <div class="text-center mb-10 order-1">
    <img alt="Logo" src="/assets/images/logo_purple.png" class="h-30px h-lg-40px" />
  </div>
  <div class="d-flex flex-column flex-lg-row-fluid w-75 w-lg-500px p-10 order-2 order-lg-1">
    <!--begin::Form-->
    <div class="d-flex flex-center flex-column flex-lg-row-fluid">
      <form
        class="form w-100"
        novalidate="novalidate"
        id="kt_password_reset_form"
        action="/reset-password"
      >
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="text-center mb-10">
          <h1 class="text-gray-900 fw-bolder mb-3">Reset Password ?</h1>
          <div class="text-gray-500 fw-semibold fs-6">Enter your email to reset your password.</div>
        </div>

        <div class="fv-row mb-8">
          <input
            type="text"
            placeholder="Email"
            name="email"
            autocomplete="off"
            class="form-control bg-transparent"
          />
        </div>

        <div class="d-flex flex-wrap justify-content-center pb-lg-0">
          <button type="button" id="kt_password_reset_submit" class="btn btn-primary me-4">
            <span class="indicator-label">Submit</span>
            <span class="indicator-progress"
              >Please wait...
              <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
            </span>
          </button>
          <a href="/login" class="btn btn-light">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
