<!-- views/layouts/auth-layout.ejs -->

<!DOCTYPE html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <base href="/" />
    <%- include("../partials/header") %>

    <!-- No page indexing -->
    <%- include("../partials/meta-noindex") %>
  </head>
  <!--end::Head-->

  <!--begin::Body-->

  <body id="kt_body" class="app-blank">
    <!--begin::Theme mode setup on page load-->
    <script>
      var defaultThemeMode = "light";
      var themeMode;
      if (document.documentElement) {
        if (document.documentElement.hasAttribute("data-bs-theme-mode")) {
          themeMode = document.documentElement.getAttribute("data-bs-theme-mode");
        } else {
          if (localStorage.getItem("data-bs-theme") !== null) {
            themeMode = localStorage.getItem("data-bs-theme");
          } else {
            themeMode = defaultThemeMode;
          }
        }
        if (themeMode === "system") {
          themeMode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
        document.documentElement.setAttribute("data-bs-theme", themeMode);
      }
    </script>
    <!--end::Theme mode setup on page load-->
    <!--begin::Root-->
    <div class="d-flex flex-column flex-root" id="kt_app_root" style="min-height: 100vh">
      <!--begin::Authentication - Sign-in -->

      <div
        class="d-flex flex-column flex-lg-row flex-column-fluid"
        style="min-height: 100vh; overflow-x: hidden"
      >
        <!--begin::Body-->
        <div
          class="d-flex flex-column flex-lg-row-fluid w-lg-50 p-10 order-2 order-lg-1 justify-content-center"
          style="flex-grow: 1"
        >
          <!--begin::Form-->

          <%- body %>

          <!--end::Form-->
        </div>
        <!--end::Body-->
        <!--begin::Aside-->
        <div
          class="d-flex flex-lg-row-fluid w-lg-50 order-2 order-lg-2"
          style="position: relative; min-height: 40vh"
        >
          <!--begin::Background Image-->
          <img
            src="/assets/images/auth-bg.png"
            alt=""
            style="
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
              object-fit: cover;
              max-width: 100%;
            "
          />
          <!--end::Background Image-->

          <!--begin::Overlay-->
          <div style="position: absolute; inset: 0; background: rgba(0, 0, 0, 0.35)"></div>
          <!--end::Overlay-->

          <!--begin::Content-->
          <div
            class="d-flex flex-column align-items-center justify-content-center px-8 px-md-16 py-12 w-100"
            style="position: relative; z-index: 1"
          >
            <div style="max-width: 420px; width: 100%">
              <!--begin::Tag-->
              <p
                class="mb-3"
                style="color: rgba(255, 255, 255, 0.6); font-size: 0.85rem; letter-spacing: 0.05em"
              >
                [ Why They Choose Us? ]
              </p>
              <!--end::Tag-->

              <!--begin::Quote-->
              <blockquote class="mb-6" style="border: none; padding: 0; margin: 0">
                <p
                  style="
                    font-size: clamp(1.1rem, 3vw, 1.6rem);
                    font-weight: 700;
                    color: #ffffff;
                    line-height: 1.4;
                  "
                >
                  "Placeholder quote that highlights the value of your platform.
                  <span style="font-weight: 400; color: rgba(255, 255, 255, 0.75)">
                    This is where the rest of the testimonial continues and sells the product."
                  </span>
                </p>
              </blockquote>
              <!--end::Quote-->

              <!--begin::Person-->
              <div class="d-flex align-items-center gap-4">
                <img
                  src="https://placehold.co/48x48"
                  alt="Avatar"
                  style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover"
                />
                <div>
                  <p class="mb-0 fw-bold" style="color: #ffffff">Placeholder Name</p>
                  <p class="mb-0" style="color: rgba(255, 255, 255, 0.6); font-size: 0.85rem">
                    Job Title @ Company
                  </p>
                </div>
              </div>
              <!--end::Person-->
            </div>
          </div>
          <!--end::Content-->
        </div>
        <!--end::Aside-->
      </div>
      <!--end::Authentication - Sign-in-->
    </div>
    <!--end::Root-->

    <!--begin::Javascript-->
    <!--begin::Global Javascript Bundle(mandatory for all pages)-->
    <%- include("../partials/footer") %>
    <!--end::Global Javascript Bundle-->

    <!--begin::Custom Javascript(used for this page only)-->
    <%- typeof scripts !=="undefined" ? scripts : "" %>
    <!--end::Custom Javascript-->
    <!--end::Javascript-->
  </body>

  <!--end::Body-->
</html>
