<!-- views/onboarding/pharmacist.ejs -->

<div class="d-flex flex-column flex-lg-row flex-column-fluid">
  <div
    class="d-flex flex-column flex-lg-row-fluid w-lg-50 p-10 order-2 order-lg-1"
  >
    <div class="d-flex flex-center flex-column flex-lg-row-fluid">
      <div class="w-75 w-lg-500px p-10">
        <div class="text-center mb-11">
          <h1 class="text-gray-900 fw-bolder mb-3">Professional Profile</h1>
          <div class="text-gray-500 fw-semibold fs-6">
            Verify your credentials to start finding locum work.
          </div>
        </div>

        <form
          action="/onboarding/pharmacist"
          method="POST"
          class="form w-100"
          id="kt_onboarding_pharmacist_form"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <!--begin::Parmacist Licence Number-->
          <div class="fv-row mb-8">
            <label class="form-label required"
              >Pharmacist Licence Number
              <span class="text-muted fs-7">
                <i
                  class="ki-outline ki-information-2 fs-6"
                  data-bs-toggle="tooltip"
                  data-bs-original-title="Your license will be verified against the PCN database."
                ></i>
              </span>
            </label>
            <input
              type="text"
              name="licenceNumber"
              class="form-control bg-transparent"
              placeholder="e.g. PH/12345/RN"
              autocomplete="off"
            />
            <div
              class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
            ></div>
          </div>
          <!--end::Parmacist Licence Number-->

          <!--begin::Phone Number-->
          <div class="fv-row mb-8">
            <label class="form-label required">Phone Number</label>
            <div class="row g-3">
              <div class="col-4">
                <select
                  name="phoneCode"
                  class="form-select bg-transparent"
                  data-kt-select2="true"
                  data-hide-search="false"
                  data-placeholder="Code"
                >
                  <option value="" disabled selected>Code</option>
                  <option value="+234">🇳🇬 +234</option>
                </select>
              </div>
              <div class="col-8">
                <input
                  type="tel"
                  name="phone"
                  class="form-control bg-transparent"
                  placeholder="08012345678"
                  autocomplete="off"
                />
                <div
                  class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
                ></div>
              </div>
            </div>
          </div>
          <!--end::Phone Number-->

          <!--begin::Primary Practice Area (Specialty)-->
          <div class="fv-row mb-8">
            <label class="form-label required">Primary Practice Area</label>
            <select
              name="specialty"
              class="form-select bg-transparent"
              data-control="select2"
              data-hide-search="false"
              data-placeholder="Select your specialty"
            >
              <option></option>
              <option value="Community">Community Pharmacy</option>
              <option value="Hospital">Hospital Pharmacy</option>
              <option value="Industrial">Industrial / Manufacturing</option>
              <option value="Academic">Academic / Research</option>
              <option value="Administrative">
                Administrative / Regulatory
              </option>
            </select>
          </div>
          <!--end::Primary Practice Area (Specialty)-->

          <!--begin::Years of Experience-->
          <div class="fv-row mb-8">
            <label class="form-label">Years of Experience</label>
            <input
              type="number"
              name="yearsOfExperience"
              class="form-control bg-transparent"
              placeholder="e.g. 3"
              min="0"
              autocomplete="off"
            />
            <div
              class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
            ></div>
          </div>
          <!--end::Years of Experience-->

          <!--begin::Location Address-->
          <div class="fv-row mb-8">
            <label class="form-label required">Location Address</label>
            <input
              type="text"
              name="address"
              class="form-control bg-transparent"
              placeholder="Location Address"
              autocomplete="off"
            />
            <div
              class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
            ></div>
          </div>
          <!--end::Location Address-->

          <!--begin::State & LGA-->
          <div class="row g-9 mb-8">
            <div class="col-md-6">
              <label class="form-label required">State</label>
              <select
                id="stateSelect"
                name="state"
                class="form-select bg-transparent"
                data-control="select2"
                data-placeholder="Select State"
              >
                <option></option>
                <% locationData.forEach(item => { %>
                <option value="<%= item.state %>"><%= item.state %></option>
                <% }); %>
              </select>
              <div
                class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
              ></div>
            </div>
            <div class="col-md-6">
              <label class="form-label required">LGA</label>
              <select
                id="lgaSelect"
                name="lga"
                class="form-select bg-transparent"
                data-control="select2"
                data-placeholder="Select LGA"
                disabled
              >
                <option value="">Select LGA</option>
              </select>
              <div class="fv-plugins-message-container invalid-feedback"></div>
            </div>
          </div>
          <!--end::State & LGA-->

          <!--begin::Professional Bio-->
          <div class="fv-row mb-10">
            <label class="form-label"
              >Professional Bio
              <span class="text-muted fs-7">
                <i
                  class="ki-outline ki-information-2 fs-6"
                  data-bs-toggle="tooltip"
                  data-bs-original-title="Briefly describe your clinical experience or specialties."
                ></i>
              </span>
            </label>
            <textarea
              name="bio"
              class="form-control bg-transparent"
              rows="4"
              placeholder="Briefly describe your clinical experience or specialties..."
            ></textarea>
            <div
              class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"
            ></div>
          </div>
          <!--end::Primary Practice Area (Specialty)-->

          <!--begin::Submit Button-->
          <div class="d-grid mb-10 mt-10">
            <button
              type="submit"
              id="kt_onboarding_pharmacist_submit"
              class="btn btn-primary"
            >
              <span class="indicator-label">Complete My Profile</span>
              <span class="indicator-progress"
                >Processing...
                <span
                  class="spinner-border spinner-border-sm align-middle ms-2"
                ></span>
              </span>
            </button>
          </div>
          <!--end::Submit Button-->
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Assigning server-side variable 'locationData' and to a browser-side variable 'window.locationData' -->
<script>
  window.locationData = <%- locationDataJson %>;
</script>
