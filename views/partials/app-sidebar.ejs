<!-- views/partials/app-sidebar.ejs -->

<div class="app-navbar flex-column flex-center py-4">
  <!--begin::Home-->
  <a
    href="<%= userHome %>"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Home"
  >
    <i class="ki-duotone ki-home-2 fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
    </i>
  </a>
  <!--end::Home-->

  <% if (user && user.role === 'pharmacist') { %>

  <!--begin::Find Shifts-->
  <a
    href="/shifts"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Find Shifts"
  >
    <i class="ki-duotone ki-magnifier fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
    </i>
  </a>
  <!--end::Find Shifts-->

  <!--begin::My Shifts-->
  <div
    data-kt-menu-trigger="{default: 'click', lg: 'hover'}"
    data-kt-menu-placement="right-start"
    data-kt-menu-attach="parent"
    class="menu menu-item py-2 mb-3"
  >
    <span class="menu-link menu-center">
      <span class="menu-icon me-0">
        <i class="ki-duotone ki-calendar fs-2x">
          <span class="path1"></span>
          <span class="path2"></span>
        </i>
      </span>
    </span>

    <div
      class="menu-sub menu-sub-dropdown menu-sub-indention px-2 py-4 w-175px"
      data-kt-menu="true"
      data-bs-placement="right-start"
    >
      <div class="menu-item">
        <div class="menu-content">
          <span class="menu-section fs-5 fw-bolder ps-1 py-1">My Shifts</span>
        </div>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/shifts/my?tab=pending">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Pending</span>
        </a>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/shifts/my?tab=confirmed">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Confirmed</span>
        </a>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/shifts/my?tab=completed">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Completed</span>
        </a>
      </div>
    </div>
  </div>
  <!--end::My Shifts-->

  <!--begin::Messages-->
  <a
    href="/messages"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Messages"
  >
    <i class="ki-duotone ki-message-text-2 fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Messages-->

  <!--begin::Profile-->
  <a
    href="/profile"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Profile"
  >
    <i class="ki-duotone ki-profile-circle fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Profile-->

  <% } else if (user && user.role === 'employer') { %>

  <!--begin::Post Shift-->
  <a
    href="/shifts/post"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Post Shift"
  >
    <i class="ki-duotone ki-plus-square fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Post Shift-->

  <!--begin::Manage Shifts-->
  <a
    href="/shifts/manage"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Manage Shifts"
  >
    <i class="ki-duotone ki-calendar-tick fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
      <span class="path4"></span>
      <span class="path5"></span>
      <span class="path6"></span>
    </i>
  </a>
  <!--end::Manage Shifts-->

  <!--begin::Applicants-->
  <a
    href="/applicants"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Applicants"
  >
    <i class="ki-duotone ki-people fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
      <span class="path4"></span>
      <span class="path5"></span>
    </i>
  </a>
  <!--end::Applicants-->

  <!--begin::Messages-->
  <a
    href="/messages"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Messages"
  >
    <i class="ki-duotone ki-message-text-2 fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Messages-->

  <!--begin::Profile-->
  <a
    href="/profile"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Profile"
  >
    <i class="ki-duotone ki-profile-circle fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Profile-->

  <% } else if (user && user.role === 'admin') { %>

  <!--begin::User Management-->
  <div
    data-kt-menu-trigger="{default: 'click', lg: 'hover'}"
    data-kt-menu-placement="right-start"
    data-kt-menu-attach="parent"
    class="menu menu-item py-2 mb-3"
  >
    <span class="menu-link menu-center">
      <span class="menu-icon me-0">
        <i class="ki-duotone ki-people fs-2x">
          <span class="path1"></span>
          <span class="path2"></span>
          <span class="path3"></span>
          <span class="path4"></span>
          <span class="path5"></span>
        </i>
      </span>
    </span>
    <div
      class="menu-sub menu-sub-dropdown menu-sub-indention px-2 py-4 w-175px"
      data-kt-menu="true"
      data-bs-placement="right-start"
    >
      <div class="menu-item">
        <div class="menu-content">
          <span class="menu-section fs-5 fw-bolder ps-1 py-1">Users</span>
        </div>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/admin/users?role=employer">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Employers</span>
        </a>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/admin/users?role=pharmacist">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Pharmacists</span>
        </a>
      </div>
    </div>
  </div>
  <!--end::User Management-->

  <!--begin::Shift Management-->
  <div
    data-kt-menu-trigger="{default: 'click', lg: 'hover'}"
    data-kt-menu-placement="right-start"
    data-kt-menu-attach="parent"
    class="menu menu-item py-2 mb-3"
  >
    <span class="menu-link menu-center">
      <span class="menu-icon me-0">
        <i class="ki-duotone ki-calendar-tick fs-2x">
          <span class="path1"></span>
          <span class="path2"></span>
          <span class="path3"></span>
          <span class="path4"></span>
          <span class="path5"></span>
          <span class="path6"></span>
        </i>
      </span>
    </span>
    <div
      class="menu-sub menu-sub-dropdown menu-sub-indention px-2 py-4 w-175px"
      data-kt-menu="true"
      data-bs-placement="right-start"
    >
      <div class="menu-item">
        <div class="menu-content">
          <span class="menu-section fs-5 fw-bolder ps-1 py-1">Shifts</span>
        </div>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/admin/shifts">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">All Shifts</span>
        </a>
      </div>
      <div class="menu-item">
        <a class="menu-link" href="/admin/shifts/post">
          <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
          <span class="menu-title">Post on Behalf</span>
        </a>
      </div>
    </div>
  </div>
  <!--end::Shift Management-->

  <!--begin::Finance-->
  <a
    href="/admin/finance"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Finance"
  >
    <i class="ki-duotone ki-dollar fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
      <span class="path3"></span>
    </i>
  </a>
  <!--end::Finance-->

  <% } %>

  <!--begin::Separator-->
  <div class="separator mb-4 border-gray-300 mx-5"></div>
  <!--end::Separator-->

  <!--begin::Settings-->
  <a
    href="/settings"
    class="btn btn-icon btn-default mx-auto mb-4"
    data-bs-toggle="tooltip"
    data-bs-placement="right"
    title="Settings"
  >
    <i class="ki-duotone ki-setting-2 fs-1">
      <span class="path1"></span>
      <span class="path2"></span>
    </i>
  </a>
  <!--end::Settings-->

  <!--begin::Logout-->
  <div class="app-navbar-item flex-center">
    <a
      href="/logout"
      class="btn btn-icon btn-color-gray-600 bg-gray-200 btn-active-primary w-40px h-40px"
      data-bs-toggle="tooltip"
      data-bs-placement="right"
      title="Logout"
    >
      <i class="ki-duotone ki-exit-right fs-1">
        <span class="path1"></span>
        <span class="path2"></span>
      </i>
    </a>
  </div>
  <!--end::Logout-->
</div>
