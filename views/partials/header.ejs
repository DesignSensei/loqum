<!-- views/partials/auth/auth-header.ejs -->

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title><%= title %> - Loqum</title>

<meta
  name="description"
  content="Find and fill locum pharmacist shifts faster. Loqum connects verified pharmacists with pharmacies that need reliable temporary coverage."
/>

<meta
  name="keywords"
  content="locum pharmacist jobs, pharmacy shifts Nigeria, hire pharmacist, temporary pharmacist staffing, pharmacist marketplace, pharmacy staffing platform"
/>

<meta name="author" content="Loqum" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content="<%= title || 'Loqum' %>" />
<meta
  property="og:description"
  content="A faster way for pharmacies to fill shifts and for pharmacists to find flexible work."
/>
<meta property="og:site_name" content="Loqum" />

<link rel="icon" href="/assets/media/logos/favicon.ico" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fustat:wght@200..800&display=swap"
  rel="stylesheet"
/>

<!-- Styles -->
<link href="/assets/plugins/global/plugins.bundle.css" rel="stylesheet" />
<link href="/assets/css/style.bundle.css" rel="stylesheet" />

<!-- Meta CSRF token -->
<meta name="csrf-token" content="<%= csrfToken %>" />

<script>
  if (window.top !== window.self) {
    window.top.location.replace(window.self.location.href);
  }
</script>
